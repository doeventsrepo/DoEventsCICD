{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3DeployDevWeb",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::doevents-web-dev",
        "arn:aws:s3:::doevents-web-dev/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidateDev",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation",
        "cloudfront:ListInvalidations"
      ],
      "Resource": "arn:aws:cloudfront::519010577666:distribution/E1AIDTCT83PAW5"
    }
  ]
}
