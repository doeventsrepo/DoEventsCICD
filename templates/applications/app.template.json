{
  "displayName": "Mi Nueva App",
  "enabled": true,
  "repositories": {
    "design": "mi-org/mi-app-lovable",
    "frontend": "mi-org/MiAppWEB",
    "backend": "mi-org/MiAppBack",
    "cicd": "mi-org/DoEventsCICD"
  },
  "branches": {
    "design": "main",
    "webCicd": "feature/cicd/dev-automation"
  },
  "paths": {
    "lovableUi": "src",
    "webLovable": "packages/shell/src/lovable",
    "webBridge": "packages/shell/src/lovable-bridge",
    "portMap": ".lovable-port-map.json"
  },
  "deploy": {
    "devDomain": "dev.miapp.com",
    "buildCommand": "npm run build:devaws",
    "buildMode": "devaws",
    "cloudProvider": "aws",
    "cloudEnv": "dev",
    "webBucket": "miapp-web-dev",
    "cloudFrontDistributionId": "CONFIGURE_DIST_ID",
    "apiDomain": "api-dev.miapp.com"
  },
  "dsf": {
    "qaPromotionBlocked": true,
    "note": "Copiar este bloque a cicd.config.json → applications.registry.<app_id>"
  },
  "appStack": {
    "validateBeforeAutomation": true,
    "autoBootstrap": true,
    "requirements": {
      "design": { "dsfStructure": true },
      "frontend": {
        "packageJson": true,
        "lovableDir": true,
        "bridgeDir": true,
        "portMap": true,
        "reglasAgente": true
      },
      "backend": {
        "optional": true,
        "note": "true si la app aún no tiene backend propio"
      }
    }
  },
  "reliability": {
    "syncAttempts": 2,
    "bridgePages": [
      {
        "lovablePath": "src/pages/Index.tsx",
        "webPath": "packages/shell/src/pages/HomePage.tsx",
        "compareMode": "bridge",
        "denyAutoComponents": [],
        "insertAfterComponents": ["FeedServicesCarousel"]
      }
    ],
    "note": "Adaptar bridgePages y webPath por app. Hereda defaults de dsf.reliability en cicd.config.json"
  }
}
