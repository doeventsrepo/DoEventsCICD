{
  "version": "1.0",
  "description": "Reglas del agente Cursor API Key para empalmar Lovable en DoEventsWEB",
  "operativas": {
    "reglamento": "Reglas/operativas/reglamento-cursor-api.md",
    "promptEmpalme": "Reglas/operativas/prompt-empalme-web.md",
    "promptGapEmpalme": "Reglas/operativas/prompt-gap-empalme.md",
    "promptFullstack": "Reglas/operativas/prompt-fullstack.md",
    "reglaComparacionDiseno": "Reglas/operativas/regla-comparacion-diseno.md"
  },
  "designComparison": {
    "script": "scripts/lovable-sync/compare-design-similarity.py",
    "reportScript": "scripts/lovable-sync/generate-design-report.py",
    "targetSimilarityPercent": 98,
    "reportsDir": "Reports"
  },
  "artefactosWeb": {
    "bootstrapTarget": "ReglasAgente",
    "templatesDir": "Reglas/artefactos-web",
    "files": [
      "reglas-front.md",
      "cambios-lovable.json",
      "decision-log.md",
      "impacto-backend.md"
    ],
    "minReglasFrontBytes": 500
  },
  "fuentesExternas": {
    "lovableBusinessRules": "reglasActuacion",
    "lovableBusinessRulesRepo": "doeventsrepo/discover-joyful-feed",
    "note": "reglasActuacion vive en el repo diseño; Reglas/ es la fuente CICD para el agente"
  },
  "gates": {
    "forbidLiteralCopy": true,
    "forbidLovableMocks": true,
    "buildCommand": "npm run build:devaws",
    "protectedBranches": ["main", "develop", "release", "release/*"],
    "outputBranch": "feature/cicd/dev-automation"
  }
}
