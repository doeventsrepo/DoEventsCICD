{
  "version": "3.0",
  "framework": "DSF",
  "description": "Reglas del agente y gates DSF para empalmar Lovable en DoEventsWEB",
  "operativas": {
    "reglamento": "Reglas/operativas/reglamento-cursor-api.md",
    "promptEmpalme": "Reglas/operativas/prompt-empalme-web.md",
    "promptGapEmpalme": "Reglas/operativas/prompt-gap-empalme.md",
    "promptFullstack": "Reglas/operativas/prompt-fullstack.md",
    "promptBackendSync": "Reglas/operativas/prompt-backend-sync.md",
    "reglaComparacionDiseno": "Reglas/operativas/regla-comparacion-diseno.md"
  },
  "customRules": {
    "dir": "Reglas/custom",
    "runner": "scripts/rules/run-custom-gates.py"
  },
  "designComparison": {
    "script": "scripts/lovable-sync/compare-design-similarity.py",
    "reportScript": "scripts/lovable-sync/generate-design-report.py",
    "syncReportScript": "scripts/lovable-sync/generate-sync-report.py",
    "targetSimilarityPercent": 98,
    "reportsDir": "Reports",
    "blockingGates": true
  },
  "artefactosWeb": {
    "bootstrapTarget": "ReglasAgente",
    "templatesDir": "Reglas/artefactos-web",
    "files": [
      "reglas-front.md",
      "cambios-lovable.json",
      "decision-log.md",
      "impacto-backend.md"
    ],
    "minReglasFrontBytes": 500
  },
  "gates": {
    "G0_portMap": "scripts/lovable-sync/validate-port-map-coverage.py",
    "G1_build": "npm run build:devaws",
    "G3_antiMocks": "scripts/lovable-sync/validate-no-mocks.sh",
    "G6_smoke": "scripts/smoke/dev-smoke.sh",
    "G_final": "scripts/lovable-sync/validate-pipeline-sync.py",
    "forbidLiteralCopy": true,
    "forbidLovableMocks": true,
    "buildCommand": "npm run build:devaws",
    "protectedBranches": ["main", "develop", "release", "release/*"],
    "outputBranch": "feature/cicd/dev-automation",
    "qaPromotionEnabled": false
  },
  "dsf": {
    "cli": "scripts/dsf",
    "mainWorkflow": "dsf-sync-dev.yml",
    "gapLoopScript": "scripts/lovable-sync/dsf-gap-loop.py",
    "providers": {
      "aws": "scripts/deploy/providers/aws-deploy.sh",
      "azure": "scripts/deploy/providers/azure-deploy.sh"
    }
  }
}
