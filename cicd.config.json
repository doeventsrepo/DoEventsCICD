{
  "version": "3.1",
  "framework": "DSF",
  "project": "DoEvents",
  "description": "Design Sync Framework multi-app — Lovable → empalme → agentes → gates → DEV. QA/prod manual.",
  "dsfCore": {
    "framework": "DSF",
    "designRepo": "doeventsrepo/discover-joyful-feed",
    "appRepo": "doeventsrepo/DoEventsWEB",
    "backendRepo": "doeventsrepo/DoEventsBack",
    "cicdRepo": "doeventsrepo/DoEventsCICD",
    "portMap": ".lovable-port-map.json",
    "rulesDir": "reglasActuacion",
    "designRulesDir": "reglasDiseno",
    "bridgeDir": "packages/shell/src/lovable-bridge",
    "lovableUiDir": "src",
    "webLovableDir": "packages/shell/src/lovable",
    "agentRulesDir": "ReglasAgente",
    "frameworkRulesDir": "templates/reglasFramework",
    "targetSimilarity": 98,
    "cloudProvider": "aws",
    "deployEnvironments": {
      "dev": { "enabled": true, "autoDeploy": true },
      "qa": { "enabled": false, "autoDeploy": false, "manualOnly": true },
      "prod": { "enabled": false, "autoDeploy": false, "manualOnly": true }
    },
    "agents": {
      "orchestrator": "scripts/agents/orchestrator.py",
      "diffIntelligence": "scripts/agents/run-diff-intelligence-agent.py",
      "portMapResolver": "scripts/agents/run-port-map-resolver-agent.py",
      "idempotencyGuard": "scripts/agents/run-idempotency-guard-agent.py",
      "conflictResolver": "scripts/agents/run-conflict-resolver-agent.py",
      "syncReadinessGate": "scripts/agents/run-sync-readiness-gate-agent.py",
      "releaseGuard": "scripts/agents/run-release-guard-agent.py",
      "dependencyGuard": "scripts/agents/run-dependency-guard-agent.py",
      "backendContractCheck": "scripts/agents/run-backend-contract-check-agent.py",
      "qualityGate": "scripts/agents/run-quality-gate-agent.py",
      "visualRegression": "scripts/agents/run-visual-regression-agent.py",
      "reportGenerator": "scripts/agents/run-report-generator-agent.py",
      "empalme": "scripts/lovable-sync/empalme-orchestrator.py",
      "gapEmpalme": "scripts/lovable-sync/dsf-gap-loop.py",
      "rulesValidation": "scripts/agents/run-rules-validation-agent.py",
      "backendAnalysis": "scripts/agents/run-backend-analysis-agent.py",
      "premergeReview": "scripts/agents/run-premerge-review-agent.py",
      "rulesRefinement": "scripts/agents/run-rules-refinement-agent.py"
    }
  },
  "phases": {
    "activeDeployEnvironment": "dev",
    "definitions": {
      "0": { "id": "bootstrap", "enabled": true, "deployTarget": null },
      "1": { "id": "lovable-trigger", "enabled": true, "deployTarget": null },
      "2": { "id": "validate-yaml", "enabled": true, "deployTarget": null },
      "3": { "id": "agent-frontend", "enabled": true, "deployTarget": "dev" },
      "4": { "id": "backend-issues", "enabled": true, "deployTarget": null, "humanApprovalRequired": true },
      "5": { "id": "fullstack", "enabled": false, "deployTarget": "dev", "humanApprovalRequired": true },
      "6": { "id": "codepipeline", "enabled": false, "deployTarget": "qa", "manualOnly": true }
    }
  },
  "repositories": {
    "cicd": "doeventsrepo/DoEventsCICD",
    "design": "doeventsrepo/discover-joyful-feed",
    "frontend": "doeventsrepo/DoEventsWEB",
    "backend": "doeventsrepo/DoEventsBack",
    "ia": "doeventsrepo/DoEventsIA"
  },
  "branches": {
    "design": "main",
    "protected": ["main", "develop", "release", "release/*"],
    "cicdWeb": "feature/cicd/dev-automation",
    "cicdBack": "feature/cicd/dev-automation",
    "cicdIa": "feature/cicd/dev-automation",
    "cicdSelf": "main",
    "agentOutputBranch": "feature/cicd/dev-automation",
    "note": "Automatización SOLO en feature/cicd/dev-automation. Prohibido push a develop/release/main."
  },
  "paths": {
    "lovableRules": "reglasActuacion",
    "lovableDesignRules": "reglasDiseno",
    "lovableEmpalmeRules": "reglasEmpalme",
    "lovableQualityRules": "reglasCalidad",
    "lovableBackendContracts": "contratosBackend",
    "agentRules": "ReglasAgente",
    "lovableUi": "src",
    "webLovable": "packages/shell/src/lovable",
    "webBridge": "packages/shell/src/lovable-bridge",
    "webPages": "packages/shell/src/pages",
    "webShared": "packages/shared",
    "cicdReglas": "Reglas",
    "cicdReglasOperativas": "Reglas/operativas",
    "cicdReglasCustom": "Reglas/custom",
    "cicdFrameworkRules": "templates/reglasFramework",
    "cicdScripts": "scripts/lovable-sync",
    "dsfCore": "dsf",
    "reportsDir": "Reports",
    "artifactsDir": "artifacts"
  },
  "dsf": {
    "targetSimilarityPercent": 98,
    "maxGapBatches": 0,
    "gapBatchSize": 20,
    "autoChainGapEmpalme": false,
    "empalmeStrategy": {
      "mode": "python-first",
      "disableGapLoop": true,
      "scope": "diff-only",
      "pythonMaxSimApply": 85,
      "maxPythonFilesPerRun": 50,
      "cursorFallbackEnabled": true,
      "cursorAutoEscalate": true,
      "maxCursorEscalations": 1,
      "maxCursorFilesPerRun": 5,
      "maxCursorRetries": 0,
      "requireCursorApproval": false,
      "antiRegression": {
        "requireBridgeMarkersPreserved": true,
        "maxWebLineDeltaMultiplier": 3,
        "maxAbsoluteWebLineDelta": 30,
        "blockOnUnappliedDelta": true,
        "note": "Bloquea empalme full-replace; delta-only sobre WEB existente. Escala a Cursor si hay regresión."
      },
      "note": "DSF v1.1 — Python empalme diff-only + delta-only anti-regresión. Sin gap-loops."
    },
    "forceAgentOnChanges": true,
    "forceAgentBelowSimilarity": true,
    "blockingGates": true,
    "requireSmokeTests": true,
    "requirePortMapCoverage": true,
    "publishBuildArtifact": true,
    "devValidationPhase": true,
    "lovableAutoSync": {
      "enabled": true,
      "triggerOnLovablePush": true,
      "targetEnvironment": "dev",
      "webBranch": "feature/cicd/dev-automation",
      "deployAfterGates": true,
      "qaPromotionBlocked": true,
      "note": "Push Lovable main → trigger-cicd-sync → DSF Sync DEV → dev.doeventsapp.com. Rama git develop NO se usa en auto-sync."
    },
    "deployDev": {
      "requireGapLoopSuccess": false,
      "note": "Desplegar DEV tras adapt+gap aunque similitud <98%; QA sigue bloqueado"
    },
    "qaPromotion": {
      "enabled": false,
      "reason": "QA inhabilitado hasta validar ciclo DEV completo (sincronización + gates + smoke)",
      "manualToken": "DEPLOY_QA_MANUAL",
      "targetBranch": "develop"
    },
    "artifactPromotion": {
      "enabled": false,
      "note": "Infraestructura lista; promoción QA deshabilitada por qaPromotion.enabled=false",
      "bucket": "doevents-cicd-artifacts-dev",
      "region": "sa-east-1"
    }
  },
  "cloud": {
    "defaultProvider": "aws",
    "providers": {
      "aws": {
        "dev": {
          "region": "sa-east-1",
          "stage": "dev",
          "web": {
            "domain": "dev.doeventsapp.com",
            "bucket": "doevents-web-dev",
            "cloudFrontDistributionId": "E1AIDTCT83PAW5"
          },
          "api": { "domain": "api-dev.doeventsapp.com" },
          "websocket": { "domain": "ws-dev.doeventsapp.com" },
          "dynamoDbSuffix": "-dev",
          "buildCommand": "npm run build:devaws",
          "buildMode": "devaws"
        },
        "qa": {
          "region": "us-east-2",
          "web": {
            "domain": "qa.doeventsapp.com",
            "bucket": "doevents-web-qa",
            "cloudFrontDistributionId": "E3UV9NHXADGSAJ"
          },
          "manualOnly": true
        }
      },
      "azure": {
        "dev": {
          "region": "eastus",
          "note": "Provider stub — configurar storageAccount y cdnEndpoint al migrar",
          "web": {
            "domain": "dev.example.com",
            "storageAccount": "CONFIGURE_AZURE_STORAGE",
            "cdnEndpoint": "CONFIGURE_AZURE_CDN"
          },
          "buildCommand": "npm run build:devaws",
          "buildMode": "devaws"
        }
      }
    }
  },
  "agent": {
    "cursorApi": "https://api.cursor.com/v1/agents",
    "defaultModel": "composer-2.5",
    "modes": ["frontend-only", "fullstack"],
    "defaultMode": "frontend-only",
    "minReglasFrontBytes": 500,
    "autoCreatePr": false,
    "includeBackend": true,
    "waitForCompletion": true,
    "strategy": "empalme",
    "forbidLiteralCopy": true,
    "forbidLovableMocks": true,
    "requireBackendIntegration": true
  },
  "pipeline": {
    "targetEnvironment": "dev",
    "targetRegion": "sa-east-1",
    "autoDeployDevOnLovableSync": true,
    "autoDeployQaOnDevelopMerge": false,
    "forbidAutomaticQaDeploy": true,
    "forbidAutomaticProdDeploy": true,
    "requireHumanApprovalForProd": true,
    "validateMocks": true,
    "validateSecrets": true,
    "validateDesignRules": true,
    "deployAfterAgentBranch": true,
    "orchestratorWorkflow": "dsf-orchestrator.yml",
    "gapEmpalmeWorkflow": "dsf-gap-empalme.yml",
    "mainWorkflow": "dsf-sync-dev.yml",
    "gapEmpalmeDefaultBatchSize": 20,
    "runMultiAgentOrchestrator": true
  }
}
